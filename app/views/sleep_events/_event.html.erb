<div id="sleep_event_<%= sleep_event.id %>" style="display: flex; align-items: center; gap: 1rem; padding: 0.4rem 0; border-bottom: 1px solid #f3f4f6;">
  <span style="font-weight: bold;"><%= sleep_event.event_type.capitalize %></span>
  <span><%= sleep_event.occurred_at.in_time_zone(sleep_session.timezone).strftime("%b %-d %H:%M") %></span>
  <%= button_to "Remove",
        sleep_session_sleep_event_path(sleep_session, sleep_event),
        method: :delete,
        style: "background:none;border:none;color:red;cursor:pointer;padding:0;font-size:0.85rem;" %>
</div>
