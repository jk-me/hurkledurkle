<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hurkledurkle" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav style="padding: 0.75rem 1rem; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center;">
      <%= link_to "Hurkledurkle", root_path, style: "font-weight: bold; text-decoration: none;" %>
      <% if authenticated? %>
        <div style="display: flex; gap: 1rem; align-items: center;">
          <%= link_to "Dashboard", dashboard_path %>
          <%= link_to "Log Sleep", new_sleep_session_path %>
          <%= link_to "Profile", edit_profile_path %>
          <%= link_to "Sign out", session_path, data: { turbo_method: :delete } %>
        </div>
      <% else %>
        <div style="display: flex; gap: 1rem;">
          <%= link_to "Sign in", new_session_path %>
          <%= link_to "Sign up", new_registration_path %>
        </div>
      <% end %>
    </nav>

    <main style="max-width: 900px; margin: 0 auto; padding: 1.5rem 1rem;">
      <% if notice %>
        <p id="notice" style="color: green; margin-bottom: 1rem;"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p id="alert" style="color: red; margin-bottom: 1rem;"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
