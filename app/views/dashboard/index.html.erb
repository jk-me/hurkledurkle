<h1>Dashboard</h1>

<div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
  <%= link_to "Last 7 days",  dashboard_path(days: 7) %>
  <%= link_to "Last 30 days", dashboard_path(days: 30) %>
  <%= link_to "Last 90 days", dashboard_path(days: 90) %>
  <span style="margin-left: auto;"><%= link_to "+ Log sleep", new_sleep_session_path %></span>
</div>

<% if @sessions_by_date.empty? %>
  <p>No sessions logged yet. <%= link_to "Log your first sleep session", new_sleep_session_path %>.</p>
<% else %>
  <section class="chart-card">
    <h2>Main timing graph</h2>
    <p class="chart-subtitle">Lines connect wind-down, sleep, wake, and rise times across days using your main sleep session for each day.</p>
    <div class="chart-legend">
      <% DashboardHelper::TIMING_SERIES.each_value do |config| %>
        <span class="chart-legend__item"><span class="chart-legend__swatch" style="background:<%= config[:color] %>"></span><%= config[:label] %></span>
      <% end %>
    </div>
    <div class="chart-wrap">
      <%= timing_graph_svg(@chart_dates, @main_sessions_by_date, @time_zone_name) %>
    </div>
  </section>

  <section class="chart-card" data-controller="tabs" data-tabs-active-value="summary">
    <h2>Calculated values</h2>
    <div class="tabs__list" role="tablist" aria-label="Calculated sleep values tabs">
      <button class="tabs__button" data-tabs-target="button" data-action="tabs#switch" data-tab="summary" role="tab" type="button">Summary</button>
      <button class="tabs__button" data-tabs-target="button" data-action="tabs#switch" data-tab="pre_sleep" role="tab" type="button">Pre-sleep</button>
      <button class="tabs__button" data-tabs-target="button" data-action="tabs#switch" data-tab="rest" role="tab" type="button">Rest</button>
      <button class="tabs__button" data-tabs-target="button" data-action="tabs#switch" data-tab="hurkle_durkle" role="tab" type="button">Hurkle-durkle</button>
    </div>

    <div data-tabs-target="panel" data-tab-panel="summary" role="tabpanel">
      <div class="chart-legend">
        <% DashboardHelper::CALCULATED_SERIES.each_value do |config| %>
          <span class="chart-legend__item"><span class="chart-legend__swatch" style="background:<%= config[:color] %>"></span><%= config[:label] %></span>
        <% end %>
      </div>
      <div class="chart-wrap">
        <%= calculated_graph_svg(@chart_dates, @main_sessions_by_date, :summary) %>
      </div>
    </div>

    <% DashboardHelper::CALCULATED_SERIES.each_key do |series_key| %>
      <div data-tabs-target="panel" data-tab-panel="<%= series_key %>" role="tabpanel" hidden>
        <div class="chart-wrap">
          <%= calculated_graph_svg(@chart_dates, @main_sessions_by_date, series_key) %>
        </div>
      </div>
    <% end %>
  </section>

  <h2>Sessions</h2>
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="border-bottom: 2px solid #e5e7eb; text-align: left;">
        <th style="padding: 0.5rem;">Date</th>
        <th style="padding: 0.5rem;">Wind-down</th>
        <th style="padding: 0.5rem;">Sleep</th>
        <th style="padding: 0.5rem;">Wake</th>
        <th style="padding: 0.5rem;">Rise</th>
        <th style="padding: 0.5rem;">Rest</th>
        <th style="padding: 0.5rem;">Pre-sleep</th>
        <th style="padding: 0.5rem;">Hurkle-durkle</th>
        <th style="padding: 0.5rem;">Type</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @sessions_by_date.each do |date, sessions| %>
        <% sessions.each do |s| %>
          <tr style="border-bottom: 1px solid #f3f4f6;" id="sleep_session_<%= s.id %>">
            <td style="padding: 0.5rem;"><%= date.strftime("%b %-d, %Y") %></td>
            <td style="padding: 0.5rem;"><%= display_local_time(s.wind_down_at, s.timezone) %></td>
            <td style="padding: 0.5rem;"><%= display_local_time(dashboard_sleep_time(s), s.timezone) %></td>
            <td style="padding: 0.5rem;"><%= display_local_time(dashboard_wake_time(s), s.timezone) %></td>
            <td style="padding: 0.5rem;"><%= display_local_time(s.rise_at, s.timezone) %></td>
            <td style="padding: 0.5rem;"><%= display_minutes(s.rest_minutes) %></td>
            <td style="padding: 0.5rem;"><%= display_minutes(s.pre_sleep_minutes) %></td>
            <td style="padding: 0.5rem;"><%= display_minutes(s.hurkle_durkle_minutes) %></td>
            <td style="padding: 0.5rem;"><%= s.is_nap ? "Nap" : "Main" %></td>
            <td style="padding: 0.5rem; text-align: right;">
              <%= link_to "Edit", edit_sleep_session_path(s) %>
              <%= button_to "Delete", sleep_session_path(s), method: :delete,
                    data: { turbo_confirm: "Delete this session?" },
                    style: "background:none;border:none;color:red;cursor:pointer;padding:0;" %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
<% end %>
