<h1>Dashboard</h1>

<div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
  <%= link_to "Last 7 days",  dashboard_path(days: 7) %>
  <%= link_to "Last 30 days", dashboard_path(days: 30) %>
  <%= link_to "Last 90 days", dashboard_path(days: 90) %>
  <span style="margin-left: auto;"><%= link_to "+ Log sleep", new_sleep_session_path %></span>
</div>

<% if @sessions_by_date.empty? %>
  <p>No sessions logged yet. <%= link_to "Log your first sleep session", new_sleep_session_path %>.</p>
<% else %>
  <div style="overflow-x: auto; margin-bottom: 2rem;">
    <div style="display: flex; align-items: flex-end; gap: 4px; min-height: 200px; border-bottom: 1px solid #ccc; padding-bottom: 4px;">
      <% (@since..Date.today).each do |date| %>
        <% day_sessions = @sessions_by_date[date] || [] %>
        <turbo-frame id="day_<%= date %>">
          <div style="text-align: center; min-width: 28px;">
            <% day_sessions.each do |s| %>
              <div style="background: <%= s.is_nap ? '#93c5fd' : '#3b82f6' %>; width: 24px; height: 40px; margin: 1px auto; cursor: pointer;"
                   onclick="location.href='<%= edit_sleep_session_path(s) %>'">
              </div>
            <% end %>
            <div style="font-size: 10px; color: #666; writing-mode: vertical-rl; transform: rotate(180deg); margin-top: 4px;">
              <%= date.strftime("%-m/%-d") %>
            </div>
          </div>
        </turbo-frame>
      <% end %>
    </div>
    <p style="font-size: 12px; color: #666; margin-top: 4px;">
      <span style="display:inline-block;width:12px;height:12px;background:#3b82f6;vertical-align:middle;"></span> Main sleep &nbsp;
      <span style="display:inline-block;width:12px;height:12px;background:#93c5fd;vertical-align:middle;"></span> Nap
    </p>
  </div>

  <h2>Sessions</h2>
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="border-bottom: 2px solid #e5e7eb; text-align: left;">
        <th style="padding: 0.5rem;">Date</th>
        <th style="padding: 0.5rem;">Wind-down</th>
        <th style="padding: 0.5rem;">Rise</th>
        <th style="padding: 0.5rem;">Rest</th>
        <th style="padding: 0.5rem;">Type</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @sessions_by_date.each do |date, sessions| %>
        <% sessions.each do |s| %>
          <tr style="border-bottom: 1px solid #f3f4f6;" id="sleep_session_<%= s.id %>">
            <td style="padding: 0.5rem;"><%= date.strftime("%b %-d, %Y") %></td>
            <td style="padding: 0.5rem;"><%= s.wind_down_at&.in_time_zone(s.timezone)&.strftime("%H:%M") %></td>
            <td style="padding: 0.5rem;"><%= s.rise_at&.in_time_zone(s.timezone)&.strftime("%H:%M") || "—" %></td>
            <td style="padding: 0.5rem;">
              <% if s.wind_down_at && s.rise_at %>
                <% mins = ((s.rise_at - s.wind_down_at) / 60).round %>
                <%= "#{mins / 60}h #{mins % 60}m" %>
              <% else %>—<% end %>
            </td>
            <td style="padding: 0.5rem;"><%= s.is_nap ? "Nap" : "Main" %></td>
            <td style="padding: 0.5rem; text-align: right;">
              <%= link_to "Edit", edit_sleep_session_path(s) %>
              <%= button_to "Delete", sleep_session_path(s), method: :delete,
                    data: { turbo_confirm: "Delete this session?" },
                    style: "background:none;border:none;color:red;cursor:pointer;padding:0;" %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
<% end %>
